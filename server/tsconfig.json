{
  "compilerOptions": {
    "target":                   "ES2020",
    "module":                   "commonjs",
    "lib":                      ["ES2020"],
    "outDir":                   "./dist",
    "strict":                   true,
    "esModuleInterop":          true,
    "experimentalDecorators":   true,
    "emitDecoratorMetadata":    true,
    "skipLibCheck":             true,
    "resolveJsonModule":        true,
    "baseUrl":                  ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*", "../shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
