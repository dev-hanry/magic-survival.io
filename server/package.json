{
  "name": "arena-server",
  "version": "1.0.0",
  "description": "Colyseus multiplayer server for Arena Game",
  "main": "dist/index.js",
  "scripts": {
    "dev":   "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@colyseus/schema": "^2.0.16",
    "colyseus":         "^0.15.20",
    "cors":             "^2.8.5",
    "express":          "^4.18.2",
    "reflect-metadata": "^0.1.14"
  },
  "devDependencies": {
    "@types/cors":    "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node":    "^20.11.5",
    "ts-node-dev":    "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript":     "^5.3.3"
  }
}
